{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LynxOCR",
  "version": "1.1.3",
  "identifier": "com.tabortao.lynxocr",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist",
    "removeUnusedCommands": true
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "LynxOCR",
        "width": 1080,
        "height": 780,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "bin/pdfium.dll"
    ]
  }
}